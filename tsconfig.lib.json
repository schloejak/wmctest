{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "module": "ES2022",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": false
  },
  "include": [
    "src/public-api.ts",
    "src/app/auth/**/*",
    "src/app/guards/**/*",
    "src/app/login/**/*",
    "src/app/home/**/*"
  ],
  "exclude": [
    "**/*.spec.ts"
  ]
}
